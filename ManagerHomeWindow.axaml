<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ShopApp.ManagerHomeWindow"
        Icon="C:\Users\brawl\OneDrive\Рабочий стол\ShopApp\Assets\Icon.jpg"
        Title="Магазин обуви - Менеджер" Width="520" Height="340">
  <Border Padding="20">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Заголовок панели (логотип слева, заголовок справа) -->
      <Grid Grid.Row="0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Image Grid.Column="0" Source="C:\Users\brawl\OneDrive\Рабочий стол\ShopApp\Assets\Icon.jpg" Width="64" Height="64" VerticalAlignment="Center" Margin="0,0,10,0"/>
        <TextBlock Grid.Column="1"
                   Text="Панель менеджера"
                   FontSize="22"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>
      </Grid>

      <!-- Крупные вертикальные кнопки по центру -->
      <StackPanel Grid.Row="1"
                  Spacing="12"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
        <Button x:Name="ProductsButton"
                Content="Товары"
                Width="220"
                Height="40"/>
        <Button x:Name="OrdersButton"
                Content="Заказы"
                Width="220"
                Height="40"/>
      </StackPanel>

      <!-- Кнопка назад снизу слева -->
      <Button Grid.Row="2"
              x:Name="BackButton"
              Content="Назад"
              Width="100"
              HorizontalAlignment="Left"
              Margin="0,10,0,0"/>
    </Grid>
  </Border>
</Window>

