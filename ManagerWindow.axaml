<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ShopApp.ManagerWindow"
        Icon="C:\Users\brawl\OneDrive\Рабочий стол\ShopApp\Assets\Icon.jpg"
        Title="Магазин обуви - Товары (менеджер)" Width="980" Height="720">
  <DockPanel>
    <!-- Верхняя панель: слева кнопка назад, справа заголовок -->
    <Grid DockPanel.Dock="Top" Margin="10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Image Grid.Column="0" Source="C:\Users\brawl\OneDrive\Рабочий стол\ShopApp\Assets\Icon.jpg" Width="40" Height="40" VerticalAlignment="Center" Margin="0,0,6,0"/>

      <TextBlock Grid.Column="1"
                 Text="Товары (менеджер)"
                 FontSize="18"
                 FontWeight="Bold"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"/>

      <Button Grid.Column="2" x:Name="BackButton" Content="Назад" Width="100"/>
    </Grid>

    <!-- Панель фильтров и поиска -->
    <StackPanel DockPanel.Dock="Top" Margin="10" Spacing="8">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <ComboBox x:Name="FilterCombo" Width="220" IsEditable="True"/>
        <ComboBox x:Name="SortCombo" Width="220">
          <ComboBoxItem Content="Без сортировки" IsSelected="True"/>
          <ComboBoxItem Content="Цена ↑" Tag="price_asc"/>
          <ComboBoxItem Content="Цена ↓" Tag="price_desc"/>
          <ComboBoxItem Content="Скидка ↑" Tag="discount_asc"/>
          <ComboBoxItem Content="Скидка ↓" Tag="discount_desc"/>
          <ComboBoxItem Content="Количество ↓" Tag="qty_desc"/>
        </ComboBox>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox x:Name="SearchBox" Width="350" Watermark="Поиск по названию, артикулу, описанию"/>
        <Button x:Name="SearchButton" Content="Искать" Width="100"/>
      </StackPanel>
    </StackPanel>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
      <StackPanel x:Name="ProductsPanel" Spacing="12"/>
    </ScrollViewer>
  </DockPanel>
</Window>

