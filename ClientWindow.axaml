<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ShopApp.ClientWindow"
        Icon="C:\Users\brawl\OneDrive\Рабочий стол\ShopApp\Assets\Icon.jpg"
        Title=" Магазин обуви - Клиент" Width="900" Height="680">
  <DockPanel>
    <!-- Верхняя панель: слева кнопка назад, по центру логотип и надпись "Товары" -->
    <Grid DockPanel.Dock="Top" Margin="10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Button x:Name="BackButton" Content="Назад" Width="100" Grid.Column="0"/>

      <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
        <Image Source="C:\Users\brawl\OneDrive\Рабочий стол\ShopApp\Assets\Icon.jpg" Width="48" Height="48" VerticalAlignment="Center"/>
        <TextBlock Text="Товары(Клиент)" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
      </StackPanel>

    </Grid>

    <!-- Поиск -->
    <StackPanel DockPanel.Dock="Top" Margin="10" Spacing="8">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox x:Name="SearchBox" Width="350" Watermark="Поиск по названию, артикулу, описанию"/>
        <Button x:Name="SearchButton" Content="Искать" Width="100" HorizontalAlignment="Left"/>
      </StackPanel>
    </StackPanel>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
      <StackPanel x:Name="ProductsPanel" Spacing="12"/>
    </ScrollViewer>
  </DockPanel>
</Window>

