<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ShopApp.OrdersWindow"
        Icon="C:\Users\brawl\OneDrive\Рабочий стол\ShopApp\Assets\Icon.jpg"
        Title="Магазин обуви - Заказы" Width="900" Height="650">
  <DockPanel>
    <!-- Верхняя панель: слева кнопки, справа заголовок -->
    <Grid DockPanel.Dock="Top" Margin="10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <StackPanel Orientation="Horizontal" Spacing="10">
        <Image Source="C:\Users\brawl\OneDrive\Рабочий стол\ShopApp\Assets\Icon.jpg" Width="40" Height="40" VerticalAlignment="Center" Margin="0,0,6,0"/>
        <Button x:Name="BackButton" Content="Назад" Width="100"/>
        <Button x:Name="AddButton" Content="Добавить" Width="110"/>
        <Button x:Name="EditButton" Content="Редактировать" Width="110"/>
        <Button x:Name="DeleteButton" Content="Удалить" Width="110"/>
      </StackPanel>

      <TextBlock Grid.Column="1"
                 Text="Заказы"
                 FontSize="18"
                 FontWeight="Bold"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center"/>
    </Grid>
    <ScrollViewer Margin="10" VerticalScrollBarVisibility="Auto">
      <StackPanel x:Name="OrdersPanel" Spacing="8"/>
    </ScrollViewer>
  </DockPanel>
</Window>

